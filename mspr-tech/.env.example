# Copier ce fichier en ".env" (non versionné, cf. .gitignore) et renseigner des valeurs propres a l'environnement.
# Aucun secret ne doit etre committe en dur dans le code ou docker-compose.yml.

# --- MinIO (cluster distribue 4 noeuds, S3-compatible, heberge en local -> conformite RGPD localisation UE/France) ---
MINIO_ROOT_USER=changeme_admin
MINIO_ROOT_PASSWORD=changeme_password_min_12_caracteres
MINIO_ENDPOINT=minio-lb:9000
MINIO_BUCKET=velib-data

# --- Kafka (cluster KRaft 3 brokers, replication factor 3 / min ISR 2) ---
# Cote hote (producteur lance en local, hors Docker) : les 3 ports exposes des 3 brokers.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093,localhost:9094
KAFKA_TOPIC_STATIONS=velib.stations.raw
KAFKA_TOPIC_DISPONIBILITE=velib.disponibilite.raw

# --- PostgreSQL (primary + replique en streaming replication) ---
POSTGRES_DB=velibdata
POSTGRES_USER=changeme_pg_user
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_HOST=localhost
# Si le port 5432 est deja occupe sur votre machine (ex: un PostgreSQL natif Windows installe
# par ailleurs), publiez postgres-primary sur un autre port via un docker-compose.override.yml
# local (non versionne, cf. .gitignore) et ajustez POSTGRES_PORT ici en consequence.
POSTGRES_PORT=5432
# Role dedie utilise par postgres-replica pour la streaming replication physique (cf. sql/init_replication.sh).
POSTGRES_REPLICATOR_USER=replicator
POSTGRES_REPLICATOR_PASSWORD=changeme_replicator_password

# --- Monitoring (Grafana) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# --- Ingestion ---
FETCH_INTERVAL_SECONDS=60
